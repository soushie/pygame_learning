import pygame

pygame.init()

screen= pygame.display.set_mode((1240,720))
clock= pygame.time.Clock()

running= True
dt=0
speed= 200

player_pos= pygame.Vector2(screen.get_width()/2,screen.get_height()/2)
man_image= pygame.image.load("assets/images/ballflying.png").convert()

man_image= pygame.transform.scale(man_image, (man_image.get_width()*6, man_image.get_height()*6))


while running:

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False


    screen.fill("white")

    screen.blit(man_image, player_pos)

    keys = pygame.key.get_pressed()
    if keys[pygame.K_w]:
        player_pos.y -= speed * dt
    if keys[pygame.K_s]:
        player_pos.y += speed * dt
    if keys[pygame.K_a]:
        player_pos.x -= speed * dt
    if keys[pygame.K_d]:
        player_pos.x += speed * dt

    pygame.display.flip()

    dt = clock.tick(60) / 1000

pygame.quit()